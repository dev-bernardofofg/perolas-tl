generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Person {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  phrases   Phrase[]
  createdAt DateTime @default(now())

  @@map("people")
}

model Phrase {
  id         Int         @id @default(autoincrement())
  text       String
  // a historinha por trás da frase — opcional, mas é o que faz rir em 2027
  context    String?
  person     Person      @relation(fields: [personId], references: [id])
  personId   Int
  utterances Utterance[]
  createdAt  DateTime    @default(now())

  @@map("phrases")
}

// Cada "+1" é um evento com data — total e mensal viram COUNT com filtro,
// e qualquer recorte futuro (semana, ano) sai sem migração.
model Utterance {
  id       Int      @id @default(autoincrement())
  phrase   Phrase   @relation(fields: [phraseId], references: [id], onDelete: Cascade)
  phraseId Int
  saidAt   DateTime @default(now())

  @@index([phraseId, saidAt])
  @@index([saidAt])
  @@map("utterances")
}
